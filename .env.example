# Copy to .env for docker compose to pick up automatically.
# Defaults below match local dev (docker compose up --build) and don't need
# to be set. Override them for a real deployment, e.g.:
#
#   CORS_ORIGINS=https://pubkey.cc,https://www.pubkey.cc
#   VITE_RELAY_WS_URL=wss://api.pubkey.cc/ws
#   VITE_RELAY_HTTP_URL=https://api.pubkey.cc

# Backend
MESSAGE_TTL_SECONDS=604800
CHALLENGE_TTL_SECONDS=60
CORS_ORIGINS=http://localhost:5173

# Frontend (baked into the JS bundle at build time, not runtime)
VITE_RELAY_WS_URL=ws://localhost:8000/ws
VITE_RELAY_HTTP_URL=http://localhost:8000
