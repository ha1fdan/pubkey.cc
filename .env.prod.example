# Copy to .env.prod and fill in real values, then:
#   docker compose -f docker-compose.prod.yml --env-file .env.prod pull
#   docker compose -f docker-compose.prod.yml --env-file .env.prod up -d
#
# Use --env-file explicitly rather than relying on a plain `.env` here: if
# this repo also has a dev `.env` (from .env.example) in the same
# directory, docker compose auto-loads *that* regardless of which -f file
# you target, and its CORS_ORIGINS=http://localhost:5173 would silently
# satisfy the "required" check below with the wrong value.
#
# There's no VITE_RELAY_WS_URL/VITE_RELAY_HTTP_URL here: those are baked
# into the frontend image at build time by CI, not read from this file.

# Required: the frontend's real origin(s), comma-separated.
CORS_ORIGINS=https://pubkey.cc,https://www.pubkey.cc

# Optional -- sane defaults if unset.
# IMAGE_TAG=latest
# MESSAGE_TTL_SECONDS=604800
# CHALLENGE_TTL_SECONDS=60
# BACKEND_PORT=8000
# FRONTEND_PORT=80
